{
  "name": "pi-agent-config",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "find . \\( -path './node_modules' -o -path './bin' -o -path './git' -o -path './npm' -o -path './sessions' -o -path '*/node_modules' -o -path '*/dist' \\) -prune -o -type f \\( -name '*.ts' -o -name '*.tsx' -o -name '*.js' -o -name '*.mjs' -o -name '*.cjs' -o -name '*.json' -o -name '*.md' \\) -print0 | xargs -0 prettier --write"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@mariozechner/pi-tui": "^0.69.0",
    "@types/node": "^24.3.0",
    "prettier": "^3.6.2",
    "typebox": "^1.1.24",
    "typescript": "^5.7.3"
  }
}
